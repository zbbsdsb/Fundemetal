  <script>
    window.__timelines = window.__timelines || {};
    var tl = gsap.timeline({ paused: true });

    // ============================================================
    // HELPER: Typewriter — split text into char spans
    // ============================================================
    function initTypewriter(el) {
      var text = el.textContent;
      el.textContent = '';
      var chars = text.split('');
      for (var i = 0; i < chars.length; i++) {
        var span = document.createElement('span');
        span.className = 'char';
        span.textContent = chars[i] === ' ' ? '\u00A0' : chars[i];
        el.appendChild(span);
      }
      return el.querySelectorAll('.char');
    }

    // ============================================================
    // SCENE 0: FADE IN  (0.0 - 0.5s)
    // ============================================================
    tl.fromTo('#scene0-inner',
      { opacity: 0 },
      { opacity: 1, duration: 0.5, ease: 'power2.out' },
      0
    );

    // ============================================================
    // SCENE 1: SHELL CRACK  (0.5 - 8.0s)
    // ============================================================
    // Module items stagger in
    tl.fromTo('.anim-s1',
      { opacity: 0, x: -30 },
      { opacity: 1, x: 0, duration: 0.5, stagger: 0.08, ease: 'power2.out' },
      0.7
    );

    // Crack edge diagonal line appears
    tl.fromTo('.s1-crack-edge',
      { opacity: 0 },
      { opacity: 1, duration: 0.3, ease: 'power2.out' },
      1.8
    );

    // Dark void expands via clip-path (the shell crack)
    tl.fromTo('.s1-void',
      { clipPath: 'polygon(0 0, 0 0, 0 0, 0 0)' },
      { clipPath: 'polygon(0 0, 100% 0, 100% 100%, 0 100%)', duration: 2.5, ease: 'power4.inOut' },
      2.0
    );

    // "This is a shell." label appears in void
    tl.fromTo('.s1-void-label',
      { opacity: 0, y: 20 },
      { opacity: 1, y: 0, duration: 0.6, ease: 'power2.out' },
      5.0
    );

    // Hard-kill scene 1 elements
    tl.set('#scene1 .anim-s1', { opacity: 0, visibility: 'hidden' }, 7.85);
    tl.set('.s1-void-label', { opacity: 0, visibility: 'hidden' }, 7.85);
    tl.set('.s1-crack-edge', { opacity: 0, visibility: 'hidden' }, 7.85);
    tl.set('.s1-void', { opacity: 0, visibility: 'hidden' }, 7.85);
    tl.set('.s1-title', { opacity: 0, visibility: 'hidden' }, 7.85);

    // ============================================================
    // SCENE 2: THE WALL  (8.0 - 16.0s)
    // ============================================================
    // Typewriter: split text, reveal char by char
    var twEl = document.getElementById('s2-typewriter');
    var twChars = initTypewriter(twEl);

    tl.fromTo(twChars,
      { opacity: 0 },
      { opacity: 1, duration: 0.01, stagger: 0.035, ease: 'steps(1, end)' },
      8.2
    );

    // Wall panel slides in from right
    tl.fromTo('#s2-wall-panel',
      { x: 380 },
      { x: 0, duration: 0.8, ease: 'power3.out' },
      8.5
