    // Questions appear one by one
    tl.fromTo('.anim-s2',
      { opacity: 0, y: 20 },
      { opacity: 1, y: 0, duration: 0.4, stagger: 0.25, ease: 'power2.out' },
      10.0
    );

    // Hard-kill scene 2
    tl.set('#s2-typewriter', { opacity: 0, visibility: 'hidden' }, 15.85);
    tl.set('#s2-wall-panel', { opacity: 0, visibility: 'hidden' }, 15.85);
    tl.set('.anim-s2', { opacity: 0, visibility: 'hidden' }, 15.85);

